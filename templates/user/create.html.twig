{% extends 'base.html.twig' %}

{% block title %}Créer un utilisateur{% endblock %}

{% block body %}

<h1>Créer un utilisateur</h1>

{{ form_start(form) }}

    {{ form_row(form.prenom) }}

    {{ form_row(form.nom) }}

    {{ form_row(form.email) }}

    <button type="submit">
        Créer
    </button>

{{ form_end(form) }}

{% endblock %}