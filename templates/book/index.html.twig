{% extends 'base.html.twig' %}

{% block title %}Hello BookController!{% endblock %}

{% block body %}


<h1>Liste des livres</h1>

  <a href="/books/create">Ajouter un livre</a>

{% for book in books %}

    <p>
        {{ book.titre }}
        {{ book.author.nom }}
        {{ book.author.prenom }}
<form action="{{ url('book_delete', { id: book.id }) }}" method="post">
    {# the argument of csrf_token() is the ID of this token #}
    <input type="hidden" name="token" value="{{ csrf_token('delete-item') }}">

    <button type="submit">Delete item </button>
</form>
    </p>

{% endfor %}

{% endblock %}